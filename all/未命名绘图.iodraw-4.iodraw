<mxfile host="www.iodraw.com" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36" version="24.7.17">
  <diagram name="第 1 页" id="ivjpOhnJxI2oSD0SUyne">
    <mxGraphModel dx="1842" dy="972" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="\begin{tikzpicture}[&#xa;  font=\footnotesize,&#xa;  &gt;=Latex,&#xa;  server/.style={&#xa;    draw=blue!70!black,&#xa;    fill=blue!8,&#xa;    rounded corners=5pt,&#xa;    line width=0.9pt,&#xa;    minimum width=3.25cm,&#xa;    minimum height=0.92cm,&#xa;    align=center&#xa;  },&#xa;  formula/.style={&#xa;    draw=blue!55!black,&#xa;    fill=blue!4,&#xa;    rounded corners=3pt,&#xa;    line width=0.7pt,&#xa;    minimum width=4.15cm,&#xa;    minimum height=0.68cm,&#xa;    align=center&#xa;  },&#xa;  client/.style={&#xa;    draw=teal!70!black,&#xa;    fill=teal!5,&#xa;    rounded corners=5pt,&#xa;    line width=0.9pt,&#xa;    minimum width=3.35cm,&#xa;    minimum height=3.15cm,&#xa;    align=center&#xa;  },&#xa;  header/.style={&#xa;    draw=teal!70!black,&#xa;    fill=teal!14,&#xa;    rounded corners=3pt,&#xa;    line width=0.55pt,&#xa;    minimum width=2.95cm,&#xa;    minimum height=0.42cm,&#xa;    align=center,&#xa;    font=\footnotesize\bfseries&#xa;  },&#xa;  chip/.style={&#xa;    draw=gray!55,&#xa;    fill=white,&#xa;    rounded corners=2pt,&#xa;    line width=0.5pt,&#xa;    minimum width=2.85cm,&#xa;    minimum height=0.39cm,&#xa;    align=center&#xa;  },&#xa;  challenge/.style={&#xa;    draw=red!60!black,&#xa;    fill=red!5,&#xa;    rounded corners=3pt,&#xa;    line width=0.7pt,&#xa;    minimum width=2.45cm,&#xa;    minimum height=0.68cm,&#xa;    align=center&#xa;  },&#xa;  solution/.style={&#xa;    draw=orange!75!black,&#xa;    fill=orange!9,&#xa;    rounded corners=4pt,&#xa;    line width=0.9pt,&#xa;    text width=11.9cm,&#xa;    align=left&#xa;  },&#xa;  down/.style={-&gt;,draw=blue!70!black,line width=0.9pt},&#xa;  up/.style={-&gt;,draw=teal!70!black,line width=0.9pt,dashed}&#xa;]&#xa;&#xa;% Server layer&#xa;\node[server] (server) at (0,3.70) {$\sum$\\[-0.5mm]\textbf{云端服务器}\\聚合结构阈值};&#xa;\node[formula] (agg) at (0,2.62) {$\displaystyle \bm{\tau}(t+1)=\frac{1}{K}\sum_{k\in\mathcal{S}_t}\bm{\tau}_k(t)$};&#xa;\draw[down] (server) -- (agg);&#xa;&#xa;% Communication buses&#xa;\draw[blue!70!black,line width=0.9pt] (-5.15,1.95) -- (5.15,1.95);&#xa;\draw[teal!70!black,line width=0.9pt,dashed] (-5.15,1.74) -- (5.15,1.74);&#xa;\draw[down] (agg.south) -- (0,1.95);&#xa;\node[blue!70!black,above] at (-4.18,1.95) {广播阈值 $\bm{\tau}(t)$};&#xa;\node[teal!70!black,below] at (4.05,1.74) {上传阈值 $\bm{\tau}_k(t)$};&#xa;&#xa;% Client cards. Fixed grid: header, icons, chips.&#xa;\foreach \x/\cid in {-5/1,0/k,5/N}{&#xa;  \node[client] (card\cid) at (\x,0.12) {};&#xa;  \node[header] at (\x,1.40) {边缘客户端 $\cid$};&#xa;&#xa;  % icon row, deliberately separated from text rows&#xa;  % phone&#xa;  \draw[rounded corners=1pt,draw=black!65,fill=white,line width=0.55pt]&#xa;    ($(\x,0.12)+(-1.15,0.46)$) rectangle ++(0.36,0.62);&#xa;  \draw[black!50,line width=0.4pt] ($(\x,0.12)+(-1.07,0.99)$) -- ++(0.20,0);&#xa;  \fill[black!55] ($(\x,0.12)+(-0.97,0.52)$) circle (0.018);&#xa;&#xa;  % data cylinder&#xa;  \draw[draw=black!55,fill=gray!10,line width=0.55pt]&#xa;    ($(\x,0.12)+(-0.32,0.46)$) rectangle ++(0.45,0.55);&#xa;  \draw[draw=black!55,fill=gray!12,line width=0.55pt]&#xa;    ($(\x,0.12)+(-0.095,1.01)$) ellipse (0.225 and 0.075);&#xa;  \draw[draw=black!55,line width=0.55pt]&#xa;    ($(\x,0.12)+(-0.095,0.46)$) ellipse (0.225 and 0.075);&#xa;&#xa;  % sparse model icon&#xa;  \begin{scope}[shift={($(\x,0.12)+(0.96,0.76)$)}]&#xa;    \foreach \p in {(-0.33,0.18),(-0.33,-0.18),(0.08,0.28),(0.08,-0.03),(0.08,-0.34),(0.48,0.12),(0.48,-0.24)}{&#xa;      \node[circle,draw=black!60,fill=orange!35,inner sep=1.2pt] at \p {};&#xa;    }&#xa;    \draw[black!55] (-0.33,0.18)--(0.08,0.28)--(0.48,0.12);&#xa;    \draw[black!55] (-0.33,-0.18)--(0.08,-0.03)--(0.48,-0.24);&#xa;    \draw[black!30] (-0.33,0.18)--(0.08,-0.03)--(0.48,-0.24);&#xa;    \draw[red!75!black,line width=0.85pt,dashed] (-0.48,0.39)--(0.62,0.39);&#xa;    \draw[red!75!black,line width=0.85pt,dashed] (-0.48,-0.42)--(0.62,-0.42);&#xa;  \end{scope}&#xa;&#xa;  \node[chip] at (\x,0.15) {私有数据 $\mathcal{D}_{\cid}$：Non-IID};&#xa;  \node[chip] at (\x,-0.52) {本地权重 $\bm{w}_{\cid}$：不上传};&#xa;  \node[chip] at (\x,-1.18) {输出稀疏模型 $\tilde{\bm{w}}_{\cid}$};&#xa;&#xa;  \draw[down] (\x,1.95) -- (\x,1.70);&#xa;  \draw[up] (\x,1.55) -- (\x,1.74);&#xa;}&#xa;&#xa;% Challenge row&#xa;\node[challenge] at (-4.85,-2.20) {$\mathcal{D}$\\数据异质};&#xa;\node[challenge] at (-1.62,-2.20) {$\uparrow\downarrow$\\通信受限};&#xa;\node[challenge] at (1.62,-2.20) {FLOPs\\计算受限};&#xa;\node[challenge] at (4.85,-2.20) {$D^*$\\密度预算};&#xa;&#xa;\node[solution] at (0,-3.42) {&#xa;\textbf{SADA-FL 应用目标：}&#xa;在不上传原始数据和完整权重的前提下，为资源受限客户端学习满足部署预算的个性化结构化稀疏模型。&#xa;\textbf{关键机制：}&#xa;Taylor 敏感度识别重要结构；可微硬掩码训练阈值；目标密度预算控制最终稀疏率；联邦通信只传输低维阈值。&#xa;};&#xa;\end{tikzpicture}" link="\begin{tikzpicture}[&#xa;  font=\footnotesize,&#xa;  &gt;=Latex,&#xa;  server/.style={&#xa;    draw=blue!70!black,&#xa;    fill=blue!8,&#xa;    rounded corners=5pt,&#xa;    line width=0.9pt,&#xa;    minimum width=3.25cm,&#xa;    minimum height=0.92cm,&#xa;    align=center&#xa;  },&#xa;  formula/.style={&#xa;    draw=blue!55!black,&#xa;    fill=blue!4,&#xa;    rounded corners=3pt,&#xa;    line width=0.7pt,&#xa;    minimum width=4.15cm,&#xa;    minimum height=0.68cm,&#xa;    align=center&#xa;  },&#xa;  client/.style={&#xa;    draw=teal!70!black,&#xa;    fill=teal!5,&#xa;    rounded corners=5pt,&#xa;    line width=0.9pt,&#xa;    minimum width=3.35cm,&#xa;    minimum height=3.15cm,&#xa;    align=center&#xa;  },&#xa;  header/.style={&#xa;    draw=teal!70!black,&#xa;    fill=teal!14,&#xa;    rounded corners=3pt,&#xa;    line width=0.55pt,&#xa;    minimum width=2.95cm,&#xa;    minimum height=0.42cm,&#xa;    align=center,&#xa;    font=\footnotesize\bfseries&#xa;  },&#xa;  chip/.style={&#xa;    draw=gray!55,&#xa;    fill=white,&#xa;    rounded corners=2pt,&#xa;    line width=0.5pt,&#xa;    minimum width=2.85cm,&#xa;    minimum height=0.39cm,&#xa;    align=center&#xa;  },&#xa;  challenge/.style={&#xa;    draw=red!60!black,&#xa;    fill=red!5,&#xa;    rounded corners=3pt,&#xa;    line width=0.7pt,&#xa;    minimum width=2.45cm,&#xa;    minimum height=0.68cm,&#xa;    align=center&#xa;  },&#xa;  solution/.style={&#xa;    draw=orange!75!black,&#xa;    fill=orange!9,&#xa;    rounded corners=4pt,&#xa;    line width=0.9pt,&#xa;    text width=11.9cm,&#xa;    align=left&#xa;  },&#xa;  down/.style={-&gt;,draw=blue!70!black,line width=0.9pt},&#xa;  up/.style={-&gt;,draw=teal!70!black,line width=0.9pt,dashed}&#xa;]&#xa;&#xa;% Server layer&#xa;\node[server] (server) at (0,3.70) {$\sum$\\[-0.5mm]\textbf{云端服务器}\\聚合结构阈值};&#xa;\node[formula] (agg) at (0,2.62) {$\displaystyle \bm{\tau}(t+1)=\frac{1}{K}\sum_{k\in\mathcal{S}_t}\bm{\tau}_k(t)$};&#xa;\draw[down] (server) -- (agg);&#xa;&#xa;% Communication buses&#xa;\draw[blue!70!black,line width=0.9pt] (-5.15,1.95) -- (5.15,1.95);&#xa;\draw[teal!70!black,line width=0.9pt,dashed] (-5.15,1.74) -- (5.15,1.74);&#xa;\draw[down] (agg.south) -- (0,1.95);&#xa;\node[blue!70!black,above] at (-4.18,1.95) {广播阈值 $\bm{\tau}(t)$};&#xa;\node[teal!70!black,below] at (4.05,1.74) {上传阈值 $\bm{\tau}_k(t)$};&#xa;&#xa;% Client cards. Fixed grid: header, icons, chips.&#xa;\foreach \x/\cid in {-5/1,0/k,5/N}{&#xa;  \node[client] (card\cid) at (\x,0.12) {};&#xa;  \node[header] at (\x,1.40) {边缘客户端 $\cid$};&#xa;&#xa;  % icon row, deliberately separated from text rows&#xa;  % phone&#xa;  \draw[rounded corners=1pt,draw=black!65,fill=white,line width=0.55pt]&#xa;    ($(\x,0.12)+(-1.15,0.46)$) rectangle ++(0.36,0.62);&#xa;  \draw[black!50,line width=0.4pt] ($(\x,0.12)+(-1.07,0.99)$) -- ++(0.20,0);&#xa;  \fill[black!55] ($(\x,0.12)+(-0.97,0.52)$) circle (0.018);&#xa;&#xa;  % data cylinder&#xa;  \draw[draw=black!55,fill=gray!10,line width=0.55pt]&#xa;    ($(\x,0.12)+(-0.32,0.46)$) rectangle ++(0.45,0.55);&#xa;  \draw[draw=black!55,fill=gray!12,line width=0.55pt]&#xa;    ($(\x,0.12)+(-0.095,1.01)$) ellipse (0.225 and 0.075);&#xa;  \draw[draw=black!55,line width=0.55pt]&#xa;    ($(\x,0.12)+(-0.095,0.46)$) ellipse (0.225 and 0.075);&#xa;&#xa;  % sparse model icon&#xa;  \begin{scope}[shift={($(\x,0.12)+(0.96,0.76)$)}]&#xa;    \foreach \p in {(-0.33,0.18),(-0.33,-0.18),(0.08,0.28),(0.08,-0.03),(0.08,-0.34),(0.48,0.12),(0.48,-0.24)}{&#xa;      \node[circle,draw=black!60,fill=orange!35,inner sep=1.2pt] at \p {};&#xa;    }&#xa;    \draw[black!55] (-0.33,0.18)--(0.08,0.28)--(0.48,0.12);&#xa;    \draw[black!55] (-0.33,-0.18)--(0.08,-0.03)--(0.48,-0.24);&#xa;    \draw[black!30] (-0.33,0.18)--(0.08,-0.03)--(0.48,-0.24);&#xa;    \draw[red!75!black,line width=0.85pt,dashed] (-0.48,0.39)--(0.62,0.39);&#xa;    \draw[red!75!black,line width=0.85pt,dashed] (-0.48,-0.42)--(0.62,-0.42);&#xa;  \end{scope}&#xa;&#xa;  \node[chip] at (\x,0.15) {私有数据 $\mathcal{D}_{\cid}$：Non-IID};&#xa;  \node[chip] at (\x,-0.52) {本地权重 $\bm{w}_{\cid}$：不上传};&#xa;  \node[chip] at (\x,-1.18) {输出稀疏模型 $\tilde{\bm{w}}_{\cid}$};&#xa;&#xa;  \draw[down] (\x,1.95) -- (\x,1.70);&#xa;  \draw[up] (\x,1.55) -- (\x,1.74);&#xa;}&#xa;&#xa;% Challenge row&#xa;\node[challenge] at (-4.85,-2.20) {$\mathcal{D}$\\数据异质};&#xa;\node[challenge] at (-1.62,-2.20) {$\uparrow\downarrow$\\通信受限};&#xa;\node[challenge] at (1.62,-2.20) {FLOPs\\计算受限};&#xa;\node[challenge] at (4.85,-2.20) {$D^*$\\密度预算};&#xa;&#xa;\node[solution] at (0,-3.42) {&#xa;\textbf{SADA-FL 应用目标：}&#xa;在不上传原始数据和完整权重的前提下，为资源受限客户端学习满足部署预算的个性化结构化稀疏模型。&#xa;\textbf{关键机制：}&#xa;Taylor 敏感度识别重要结构；可微硬掩码训练阈值；目标密度预算控制最终稀疏率；联邦通信只传输低维阈值。&#xa;};&#xa;\end{tikzpicture}" id="6Z4aVBTrFUl1EG5fvemW-1">
